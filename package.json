    "autoprefixer": "^10.4.20",
    "happy-dom": "^16.5.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wxt": "^0.19.27"
